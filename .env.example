# Django
SECRET_KEY=change-me-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database (PostgreSQL on RDS or local)
DATABASE_URL=postgres://doclate:password@localhost:5432/doclate_db

# AWS
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=doclate-documents
AWS_S3_REGION_NAME=ap-south-1

# AWS SES (email)
AWS_SES_REGION_NAME=ap-south-1
DEFAULT_FROM_EMAIL=noreply@doclate.aiyug.com

# Redis (for Celery task queue)
REDIS_URL=redis://localhost:6379/0

# Frontend URL (CORS)
FRONTEND_URL=http://localhost:5173

# Signing
SIGNING_LINK_EXPIRY_DAYS=7
OTP_VALIDITY_SECONDS=300
